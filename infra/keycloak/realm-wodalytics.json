{
  "realm": "wodalytics",
  "displayName": "WODalytics",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginTheme": "wodalytics",
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 604800,
  "ssoSessionMaxLifespan": 604800,
  "offlineSessionMaxLifespanEnabled": false,
  "attributes": {
    "userProfileConfig": "{\"attributes\":[{\"name\":\"username\",\"displayName\":\"${username}\",\"validations\":{\"length\":{\"min\":3,\"max\":255},\"username-prohibited-characters\":{},\"up-username-not-idn-homograph\":{}},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"email\",\"displayName\":\"${email}\",\"validations\":{\"email\":{},\"length\":{\"max\":255}},\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"firstName\",\"displayName\":\"${firstName}\",\"validations\":{\"length\":{\"max\":255},\"person-name-prohibited-characters\":{}},\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"lastName\",\"displayName\":\"${lastName}\",\"validations\":{\"length\":{\"max\":255},\"person-name-prohibited-characters\":{}},\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false}],\"groups\":[{\"name\":\"user-metadata\",\"displayHeader\":\"User metadata\",\"displayDescription\":\"Attributes, which refer to user metadata\"}],\"unmanagedAttributePolicy\":\"ENABLED\"}"
  },
  "clientScopes": [
    {
      "name": "wodalytics-claims",
      "description": "WODalytics user ID and role as JWT claims",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "false"
          }
        },
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "false",
            "user.attribute": "email",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        },
        {
          "name": "name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "false",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "wodalytics_user_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "false",
            "user.attribute": "wodalytics_user_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "wodalytics_user_id",
            "jsonType.label": "String"
          }
        },
        {
          "name": "wodalytics_role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "false",
            "user.attribute": "wodalytics_role",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "wodalytics_role",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "name": "wodalytics:workouts:read",
      "description": "Read workouts and programs the user has access to",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "Read workouts and programs accessible to your account"
      }
    },
    {
      "name": "wodalytics:results:read",
      "description": "Read own results and public leaderboards",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "Read your workout results and leaderboards"
      }
    },
    {
      "name": "wodalytics:results:write",
      "description": "Log results for accessible workouts",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "Log and edit your workout results"
      }
    },
    {
      "name": "wodalytics:programs:write",
      "description": "Create workouts in personal program",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "Create workouts in your personal program"
      }
    }
  ],
  "clients": [
    {
      "clientId": "wodalytics-web",
      "name": "WODalytics Web",
      "description": "Web SPA — public client with PKCE. No client secret: the app runs entirely in the browser and cannot securely store one (OAuth 2.1 §2.1.1).",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "redirectUris": [
        "https://qa.wodalytics.com/*",
        "http://local.wodalytics.com/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "https://qa.wodalytics.com",
        "http://local.wodalytics.com",
        "http://localhost:5173",
        "+"
      ],
      "defaultClientScopes": [
        "wodalytics-claims"
      ],
      "optionalClientScopes": [
        "offline_access"
      ]
    },
    {
      "clientId": "wodalytics-mobile",
      "name": "WODalytics Mobile",
      "description": "Mobile app — public client with PKCE",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "redirectUris": [
        "com.wodalytics.app://*",
        "exp://localhost:*",
        "exp://127.0.0.1:*"
      ],
      "webOrigins": [],
      "defaultClientScopes": [
        "wodalytics-claims"
      ],
      "optionalClientScopes": [
        "offline_access"
      ]
    },
    {
      "clientId": "wodalytics-mcp",
      "name": "WODalytics MCP",
      "description": "MCP server — public client with PKCE + DPoP for AI agent authorization",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "dpop.bound.access.tokens": "true"
      },
      "protocolMappers": [
        {
          "name": "mcp-server-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "https://mcp.qa.wodalytics.com",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ],
      "redirectUris": [
        "https://mcp.qa.wodalytics.com/callback",
        "http://localhost:*",
        "https://claude.ai/api/mcp/auth_callback"
      ],
      "webOrigins": [
        "https://mcp.qa.wodalytics.com",
        "https://claude.ai"
      ],
      "defaultClientScopes": [
        "wodalytics-claims"
      ],
      "optionalClientScopes": [
        "wodalytics:workouts:read",
        "wodalytics:results:read",
        "wodalytics:results:write",
        "wodalytics:programs:write",
        "offline_access"
      ]
    },
    {
      "clientId": "https://chatgpt.com/oauth/OeoXtI1ZiAFo/client.json",
      "name": "ChatGPT MCP",
      "description": "ChatGPT MCP connector — pre-registered CIMD client. KC 26.6 CIMD does not support inline auth-time lookup for unregistered URL clients; this static entry acts as the workaround until KC gains that capability. client_id = the ChatGPT integration's CIMD document URL. Uses private_key_jwt auth (RFC 7523) — no shared secret; KC verifies tokens against ChatGPT's JWKS.",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-jwt",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "use.jwks.url": "true",
        "jwks.url": "https://chatgpt.com/oauth/jwks.json",
        "token.endpoint.auth.signing.alg": "RS256"
      },
      "protocolMappers": [
        {
          "name": "mcp-server-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "https://mcp.qa.wodalytics.com",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ],
      "redirectUris": [
        "https://chatgpt.com/connector/oauth/OeoXtI1ZiAFo"
      ],
      "webOrigins": [
        "https://chatgpt.com"
      ],
      "defaultClientScopes": [
        "wodalytics-claims"
      ],
      "optionalClientScopes": [
        "wodalytics:workouts:read",
        "wodalytics:results:read",
        "wodalytics:results:write",
        "wodalytics:programs:write",
        "offline_access"
      ]
    }
  ],
  "clientProfiles": {
    "profiles": [
      {
        "name": "mcp-cimd-profile",
        "description": "Client ID Metadata Document profile — any MCP client with a valid CIMD document is accepted (https required)",
        "executors": [
          {
            "executor": "client-id-metadata-document",
            "configuration": {
              "allow-http-scheme": false,
              "trusted-domains": [],
              "restrict-same-domain": false,
              "required-properties": [],
              "only-allow-confidential-client": false
            }
          }
        ]
      }
    ]
  },
  "clientPolicies": {
    "policies": [
      {
        "name": "mcp-cimd-policy",
        "description": "Apply CIMD profile to any client whose client_id is an https URL — no domain allowlist, any valid CIMD document is accepted",
        "enabled": true,
        "conditions": [
          {
            "condition": "client-id-uri",
            "configuration": {
              "uri-scheme": ["https"],
              "trusted-domains": []
            }
          }
        ],
        "profiles": ["mcp-cimd-profile"]
      }
    ]
  },
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "__GOOGLE_IDP_CLIENT_ID__",
        "clientSecret": "__GOOGLE_IDP_CLIENT_SECRET__",
        "syncMode": "IMPORT",
        "hostedDomain": ""
      }
    }
  ],
  "identityProviderMappers": [
    {
      "name": "google-email-mapper",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "user.attribute": "email",
        "claim": "email"
      }
    }
  ]
}
