{
  "name": "@berntracker/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "../../node_modules/.bin/nodemon",
    "build": "tsc",
    "start": "node --env-file=../../.env dist/index.js",
    "job": "node --env-file=../../.env dist/jobs/index.js",
    "test": "NODE_OPTIONS='--conditions=source' npx dotenv-cli -e ../../.env -- sh -c 'for f in tests/*.ts; do npx tsx \"$f\" || exit 1; done'"
  },
  "dependencies": {
    "@berntracker/db": "*",
    "@berntracker/types": "*",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "fuse.js": "^7.3.0",
    "google-auth-library": "^10.6.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.9",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
