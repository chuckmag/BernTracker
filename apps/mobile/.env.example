# ─── Mobile public env vars ───────────────────────────────────────────────────
# Expo only reads .env from the Expo project directory (apps/mobile/), not the
# monorepo root. Copy this file to apps/mobile/.env and fill in your values.
#
# EXPO_PUBLIC_ prefix is required for values to be accessible in client-side
# (bundled) code. These are public client IDs — safe to expose in the app.

# API base URL (must be reachable from the device — see root .env.example)
EXPO_PUBLIC_API_URL="http://localhost:3000"

# Google OAuth client IDs
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID — same value as GOOGLE_IOS_CLIENT_ID in root .env
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID — same value as GOOGLE_CLIENT_ID in root .env
#   (used by the Expo Go auth proxy during development)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
