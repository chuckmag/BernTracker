# ─── Mobile public env vars ───────────────────────────────────────────────────
# Expo only reads .env from the Expo project directory (apps/mobile/), not the
# monorepo root. Copy this file to apps/mobile/.env and fill in your values.
#
# EXPO_PUBLIC_ prefix is required for values to be accessible in client-side
# (bundled) code.

# API base URL (must be reachable from the device).
# Google OAuth uses the server-side redirect flow — the mobile app opens
# ${EXPO_PUBLIC_API_URL}/api/auth/google in a webview and the API does the
# full OAuth handshake. So no Google client IDs are needed in the mobile env;
# only this URL matters.
# - For local dev on a simulator: http://localhost:3000
# - For Expo Go on a physical device: http://<your-LAN-IP>:3000
# - For testing against the hosted QA stack: https://qa.wodalytics.com
EXPO_PUBLIC_API_URL="https://qa.wodalytics.com"

# ─── EAS / OTA — OPTIONAL ─────────────────────────────────────────────────────
# `app.config.ts` reads EAS_PROJECT_ID from process.env and only emits
# `updates.url` / `extra.eas.projectId` when it's set. Leave it unset for
# normal local dev so `expo-updates` stays quiet. EAS builds inject it
# automatically via `eas.json`, so this is only needed if you want to exercise
# OTA updates from `expo start`.
# EAS_PROJECT_ID="f0a6deb9-d571-4d24-9e33-d456bf16ebe3"
