{
  "name": "berntracker",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "cd apps/api && npm run dev",
    "dev:jobs": "cd apps/api && npm run job",
    "dev:web": "cd apps/web && npm run dev",
    "dev:mobile": "cd apps/mobile && npm run dev",
    "dev:worktree": "node scripts/dev-worktree.mjs",
    "test:worktree": "node scripts/test-worktree.mjs",
    "find-free-ports": "node scripts/find-free-ports.mjs",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:migrate": "npm run db:migrate --workspace=packages/db",
    "db:studio": "npm run db:studio --workspace=packages/db"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
