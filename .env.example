# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wodalytics"

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="also-change-me-in-production"
NODE_ENV="development"
# Comma-separated list of origins the API will accept CORS requests from.
# Docker compose overrides this to include http://local.wodalytics.com.
# In Railway QA / prod, set to the deployed web's origin (e.g. https://wodalytics-qa-web.up.railway.app).
ALLOWED_ORIGINS="http://localhost:5173"

# ─── Auth (Slice 2) ────────────────────────────────────────────────────────────
# Google OAuth (web client) — also used by the mobile app via the server-side
# redirect flow: mobile opens ${API_URL}/api/auth/google, the API does the full
# OAuth handshake against Google with these credentials, then redirects to the
# app scheme with our own JWT. The iOS/Android client IDs are NOT needed —
# Google never sees the mobile app, only this web client.
GOOGLE_CLIENT_ID=967542660167-dhm3mjldvtlm6l4igd6ueq2cvft090u8.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=fakesecret
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
FRONTEND_URL="http://localhost:5173"

# ─── Mobile ───────────────────────────────────────────────────────────────────
# Expo public vars (EXPO_PUBLIC_API_URL) live in apps/mobile/.env — Expo only
# reads .env from its own project directory. See apps/mobile/.env.example.

# ─── Movements ────────────────────────────────────────────────────────────────
MOVEMENT_REVIEWER_EMAIL=   # email address allowed to review pending movement suggestions

# ─── WODalytics Admin ─────────────────────────────────────────────────────────
# Comma-separated list of emails granted access to the WODalytics admin
# surface (edit unaffiliated/public-catalog programs and their workouts).
# Empty / unset → all /api/admin/* routes return 403 (deny by default).
WODALYTICS_ADMIN_EMAILS=
