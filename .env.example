# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/berntracker"

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="also-change-me-in-production"
NODE_ENV="development"

# ─── Auth (Slice 2) ────────────────────────────────────────────────────────────
# Google OAuth — server-side (web client)
GOOGLE_CLIENT_ID=967542660167-dhm3mjldvtlm6l4igd6ueq2cvft090u8.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=fakesecret

# Google OAuth — mobile public client IDs (no secret; safe to expose in app)
GOOGLE_IOS_CLIENT_ID=967542660167-ircfnmum03iap9fefa7o6nutgbsubf51.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=TODO

# EXPO_PUBLIC_ prefix makes these accessible in Expo client-side code (LoginScreen).
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID  — same as GOOGLE_IOS_CLIENT_ID above
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID  — same as GOOGLE_CLIENT_ID above; used by
#   the Expo Go auth proxy (routes through auth.expo.io during development).
#   Add https://auth.expo.io/@<your-expo-username>/berntracker to the allowed
#   redirect URIs for this client in Google Cloud Console.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=967542660167-ircfnmum03iap9fefa7o6nutgbsubf51.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=967542660167-dhm3mjldvtlm6l4igd6ueq2cvft090u8.apps.googleusercontent.com
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
FRONTEND_URL="http://localhost:5173"

# ─── Mobile ───────────────────────────────────────────────────────────────────
# API base URL used by the Expo mobile app (must be reachable from the device).
#
#   iOS/Android simulator:  http://localhost:3000  (default, works out of the box)
#   Physical device:        http://<your-mac-local-ip>:3000
#
# Your Mac's local IP changes with each network. Find it with:
#   ipconfig getifaddr en0
#
# Without this set correctly, the app will open but every API call will fail silently.
EXPO_PUBLIC_API_URL="http://localhost:3000"
